# Copy this file to .env and fill in your own key — never commit the real .env file.
# Get a free OpenRouter key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the default model. Free-tier model IDs change over time,
# so check https://openrouter.ai/models?max_price=0 for what's currently available.
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
