# Copy this file to .env and fill in your own key — never commit the real .env file.
# Get a free OpenRouter key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the model. Default is "openrouter/free", OpenRouter's own
# router that auto-selects among whatever free models are currently available —
# this avoids hardcoding a specific free slug that can be discontinued later.
# Pin a specific model instead if you want consistent behavior, e.g.:
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
